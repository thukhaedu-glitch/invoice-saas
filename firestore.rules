rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /publicVerifications/{verificationId} {
      allow read: if true;
      allow create, update: if request.auth != null
        && request.resource.data.companyId is string
        && exists(/databases/$(database)/documents/companies/$(request.resource.data.companyId))
        && get(/databases/$(database)/documents/companies/$(request.resource.data.companyId)).data.members[request.auth.uid] != null;
      allow delete: if request.auth != null
        && resource.data.companyId is string
        && exists(/databases/$(database)/documents/companies/$(resource.data.companyId))
        && get(/databases/$(database)/documents/companies/$(resource.data.companyId)).data.members[request.auth.uid] != null;
    }

    match /upgradeRequests/{reqId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /coupons/{couponId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /config/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /users/{userId} {
      allow read, write: if request.auth != null;
    }
    match /companies/{companyId} {
      allow read, write: if request.auth != null;
    }
    match /companies/{companyId}/{document=**} {
      allow read, write: if request.auth != null;
    }
    match /salesReps/{repId} {
      allow read, write: if request.auth != null;
    }
    match /leads/{leadId} {
      allow read, write: if request.auth != null;
    }
    match /crmClients/{clientId} {
      allow read, write: if request.auth != null;
    }
    match /followUps/{id} {
      allow read, write: if request.auth != null;
    }
    match /commissions/{id} {
      allow read, write: if request.auth != null;
    }
    match /pendingAccounts/{id} {
      allow read, write: if request.auth != null;
    }
    match /userNotes/{userId}/{document=**} {
      allow read, write: if request.auth != null;
    }
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
